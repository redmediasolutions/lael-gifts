---
interface Props { active?: string; }
const { active = 'shop' } = Astro.props;
const links = [
  { label: 'Shop', href: '/shop', key: 'shop' },
  { label: 'About', href: '/about', key: 'about' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];
---

<header class="site-header">
  <div class="container bar">
    <nav class="nav-left">
      {links.map((l) => (
        <a href={l.href} class={active === l.key ? 'nav-link active' : 'nav-link'}>{l.label}</a>
      ))}
    </nav>

    <a href="/" class="logo">SERENE GIFTING</a>

    <div class="nav-right">
      <button class="icon" aria-label="Search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line>
        </svg>
      </button>
      <button class="icon" aria-label="Account">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="8" r="4"></circle><path d="M4 20c0-4 4-6 8-6s8 2 8 6"></path>
        </svg>
      </button>
      <button class="icon cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M6 8h12l-1 12H7L6 8z"></path><path d="M9 8a3 3 0 0 1 6 0"></path>
        </svg>
        <span class="badge">2</span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 66px;
  }
  .nav-left { display: flex; gap: 26px; }
  .nav-link { font-size: 0.82rem; color: var(--ink); padding-bottom: 2px; }
  .nav-link.active { border-bottom: 1.5px solid var(--accent); color: var(--accent); }

  .logo {
    text-align: center;
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    white-space: nowrap;
  }

  .nav-right { display: flex; justify-content: flex-end; gap: 16px; }
  .icon {
    position: relative; background: none; border: none; color: var(--ink);
    cursor: pointer; padding: 4px; display: inline-flex;
  }
  .badge {
    position: absolute; top: -2px; right: -4px;
    background: var(--accent); color: #fff; font-family: var(--sans);
    font-size: 0.6rem; line-height: 1; padding: 3px 4px; border-radius: 999px;
  }

  @media (max-width: 720px) {
    .nav-left { gap: 16px; }
    .logo { font-size: 1.05rem; letter-spacing: 0.14em; }
  }
</style>
