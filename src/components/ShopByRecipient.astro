---
const forHer =
  'https://images.unsplash.com/photo-1602874801007-bd458bb1b8b6?auto=format&fit=crop&w=1000&q=80';
const forHim =
  'https://images.unsplash.com/photo-1544816155-12df9643f363?auto=format&fit=crop&w=800&q=80';
const homeDecor =
  'https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=800&q=80';
---

<section class="recipients">
  <div class="container">
    <div class="section-head">
      <div>
        <h2>Shop by Recipient</h2>
        <p class="sub">Find the perfect gesture for every person in your life.</p>
      </div>
      <a href="#" class="link-underline">View All</a>
    </div>

    <div class="grid">
      <a href="#" class="card tall">
        <img src={forHer} alt="For Her — candle, silk eye mask and botanical oils" />
        <div class="card-caption">
          <h3>For Her</h3>
          <span class="cap-sub">Explore Collection</span>
        </div>
      </a>

      <div class="stack">
        <a href="#" class="card">
          <img src={forHim} alt="For Him — leather journal and pen" />
          <div class="card-caption">
            <h3>For Him</h3>
            <span class="cap-sub">Shop Now</span>
          </div>
        </a>
        <a href="#" class="card">
          <img src={homeDecor} alt="Home Decor — curated interior pieces" />
          <div class="card-caption">
            <h3>Home Decor</h3>
            <span class="cap-sub">Curated Items</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .recipients { background: var(--cream); }
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 30px;
  }
  .section-head h2 { font-size: 1.9rem; }
  .sub { margin: 8px 0 0; font-size: 0.86rem; color: var(--muted); }

  .grid {
    display: grid;
    grid-template-columns: 1.9fr 1fr;
    gap: 18px;
  }
  .stack { display: grid; grid-template-rows: 1fr 1fr; gap: 18px; }

  .card {
    position: relative;
    overflow: hidden;
    display: block;
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .card:hover img { transform: scale(1.04); }
  .card.tall img { min-height: 440px; }
  .stack .card img { min-height: 211px; }

  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,16,12,0.55), rgba(20,16,12,0) 55%);
  }
  .card-caption {
    position: absolute;
    left: 22px;
    bottom: 20px;
    z-index: 2;
    color: #fff;
  }
  .card-caption h3 {
    font-style: italic;
    font-size: 1.6rem;
    color: #fff;
  }
  .cap-sub {
    display: block;
    margin-top: 4px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
  }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
    .card.tall img { min-height: 320px; }
    .stack .card img { min-height: 180px; }
  }
</style>
